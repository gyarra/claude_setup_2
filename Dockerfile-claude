FROM node:20-slim

# Install system packages including gh CLI and sudo
RUN apt-get update && apt-get install -y \
    bash \
    curl \
    file \
    git \
    openssh-client \
    python3 \
    python3-pip \
    jq \
    sudo \
    xxd \
    && rm -rf /var/lib/apt/lists/*

# Install Chromium and its dependencies
RUN apt-get update && apt-get install -y \
    chromium \
    chromium-sandbox \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libgbm1 \
    libgtk-3-0 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Install uv (Python package manager) — copy binary directly from official image
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Install Claude Code
RUN npm install -g @anthropic-ai/claude-code

# Install Playwright CLI, browser binaries, and Claude Code skill
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN npm install -g @playwright/cli@latest \
    && playwright-cli install-browser \
    && playwright-cli install --skills \
    && chmod -R a+rX /opt/playwright-browsers

# Symlink Chromium to the path chrome-launcher expects for Google Chrome stable
RUN mkdir -p /opt/google/chrome \
    && ln -s /usr/bin/chromium /opt/google/chrome/chrome

# Tell Puppeteer where to find Chromium (chrome-devtools-mcp uses --executablePath from docker/mcp.json)
ENV CHROME_PATH=/usr/bin/chromium
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Create user with sudo access, and own /workspace
RUN useradd -m -s /bin/bash claude \
    && echo "claude ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/claude \
    && mkdir -p /workspace \
    && chown claude:claude /workspace

# Pre-populate GitHub's SSH host key to avoid interactive prompt
RUN mkdir -p /home/claude/.ssh \
    && ssh-keyscan github.com >> /home/claude/.ssh/known_hosts \
    && chown -R claude:claude /home/claude/.ssh

# Bake Docker-specific MCP config and init script into the image
COPY docker/mcp.json /home/claude/mcp.json
COPY docker/init.sh /home/claude/init.sh
RUN chown claude:claude /home/claude/mcp.json /home/claude/init.sh

WORKDIR /workspace
USER claude

CMD ["bash"]
